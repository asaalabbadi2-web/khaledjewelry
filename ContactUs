<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>تواصل معنا | مجوهرات خالد</title>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-gold: #C4A77D;
            --dark-gold: #A6895A;
            --bg-cream: #FCF9F2;
            --text-dark: #2C2C2C;
            --white: #ffffff;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background-color: var(--bg-cream);
            color: var(--text-dark);
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .contact-card {
            background: var(--white);
            width: 100%;
            max-width: 450px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            overflow: hidden;
            margin: 20px;
            border: 1px solid rgba(196, 167, 125, 0.2);
        }

        .header {
            background-color: var(--primary-gold);
            padding: 40px 20px;
            text-align: center;
            color: var(--white);
        }

        .logo-placeholder {
            font-size: 24px;
            font-weight: 700;
            border: 2px solid var(--white);
            display: inline-block;
            padding: 10px 20px;
            margin-bottom: 10px;
        }

        .company-name {
            margin: 10px 0 5px;
            font-size: 22px;
        }

        .company-name-en {
            font-size: 14px;
            opacity: 0.9;
            letter-spacing: 1px;
        }

        .content {
            padding: 30px 20px;
        }

        .contact-item {
            display: flex;
            align-items: center;
            background: var(--bg-cream);
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 15px;
            text-decoration: none;
            color: var(--text-dark);
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .contact-item:hover {
            border-color: var(--primary-gold);
            transform: translateY(-2px);
        }

        .icon {
            width: 40px;
            height: 40px;
            background: var(--primary-gold);
            color: white;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-left: 15px;
            font-size: 18px;
        }

        .info-text h4 {
            margin: 0;
            font-size: 13px;
            color: var(--dark-gold);
        }

        .info-text p {
            margin: 2px 0 0;
            font-weight: 500;
        }

        .legal-footer {
            padding: 20px;
            text-align: center;
            font-size: 11px;
            color: #888;
            border-top: 1px solid #f0f0f0;
        }

        .legal-item {
            margin-bottom: 5px;
        }

        .status-badge {
            font-size: 10px;
            background: #eee;
            padding: 2px 8px;
            border-radius: 10px;
            color: #666;
        }
    </style>
</head>
<body>

<div class="contact-card">
    <div class="header">
        <div class="logo-placeholder">K</div>
        <h1 class="company-name">مجوهرات خالد</h1>
        <div class="company-name-en">KHALED JEWELRY CO.</div>
    </div>

    <div class="content">
        <a href="https://wa.me/966507678158" class="contact-item">
            <div class="icon">💬</div>
            <div class="info-text">
                <h4>واتساب / اتصال</h4>
                <p>+966 507678158</p>
            </div>
        </a>

        <a href="https://instagram.com/khaledjewels.sa" class="contact-item">
            <div class="icon">📸</div>
            <div class="info-text">
                <h4>إنستغرام</h4>
                <p>@khaledjewels.sa</p>
            </div>
        </a>

        <a href="https://snapchat.com/add/khaledjewels.sa" class="contact-item">
            <div class="icon">👻</div>
            <div class="info-text">
                <h4>سناب شات</h4>
                <p>@khaledjewels.sa</p>
            </div>
        </a>

        <a href="https://maps.google.com/?q=الطائف_المملكة_العربية_السعودية" class="contact-item">
            <div class="icon">📍</div>
            <div class="info-text">
                <h4>الموقع</h4>
                <p>الطائف، المملكة العربية السعودية</p>
            </div>
        </a>

        <div class="contact-item" style="cursor: default;">
            <div class="icon">🌐</div>
            <div class="info-text">
                <h4>الموقع الإلكتروني</h4>
                <p>khaledjewelry.sa <span class="status-badge">قيد الإنشاء</span></p>
            </div>
        </div>
    </div>

    <div class="legal-footer">
        <div class="legal-item">السجل التجاري: 7003475030</div>
        <div class="legal-item">الرقم الضريبي: 311326867900003</div>
        <div class="legal-item" style="margin-top: 10px; font-weight: bold;">بريق الذهب.. وجمال الياقوت</div>
    </div>
</div>

</body>
</html>
